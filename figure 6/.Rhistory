if (!require("circlize")) install.packages("circlize")
library(circlize)
# 1. Initialize Genome Dimensions
scaffold_size <- 5000000
circos.clear()
circos.par("gap.degree" = 2, "start.degree" = 90, "track.margin" = c(0.005, 0.005))
circos.initialize("MDCuke_2022", xlim = c(0, scaffold_size))
# 2. Data Definitions (Based on your Hinge-Furnace Scaffold)
# Track 1: Furnace Peaks (Omega = 4.21)
furnace_data <- data.frame(
start = c(50000, 1200000, 2500000, 3800000, 4700000),
end =   c(150000, 1350000, 2650000, 3950000, 4850000)
)
# Track 2: Hinge Positions (IS-elements / Blue arrows)
hinge_data <- data.frame(
pos = c(100000, 600000, 1300000, 2000000, 2600000, 3300000, 3900000, 4500000)
)
# -------------------------------------------------------------------
# TRACK 1: OUTER SELECTION PRESSURE (Adaptive Furnace)
# -------------------------------------------------------------------
# Red markers representing High-Velocity Furnace zones (r/m = 4.21)
circos.track(ylim = c(0, 1), track.height = 0.05, bg.border = NA, panel.fun = function(x, y) {
for(i in 1:nrow(furnace_data)) {
circos.rect(furnace_data$start[i], 0, furnace_data$end[i], 1, col = "#FF0000", border = NA)
}
})
# -------------------------------------------------------------------
# TRACK 2: GENOMIC BLOCKS (Blue/Purple Adaptive Rings)
# -------------------------------------------------------------------
circos.track(ylim = c(0, 1), track.height = 0.15, bg.col = "#4A90E2", bg.border = "white")
# -------------------------------------------------------------------
# TRACK 3: GC CONTENT / GENOMIC COMPLEXITY (Grey Skyline)
# -------------------------------------------------------------------
# Replicating the jagged grey track from your tif file
circos.track(ylim = c(0, 1), track.height = 0.15, bg.border = NA, panel.fun = function(x, y) {
x_gc <- seq(0, scaffold_size, by = 10000)
y_gc <- runif(length(x_gc), 0.2, 0.8)
circos.lines(x_gc, y_gc, col = "#7F8C8D", lwd = 0.5, type = "h")
})
# -------------------------------------------------------------------
# TRACK 4: THE IS-HINGE VENTS (Orange/Blue Markers)
# -------------------------------------------------------------------
# Specific anchors for adaptive tempo
circos.track(ylim = c(0, 1), track.height = 0.05, bg.border = NA, panel.fun = function(x, y) {
for(i in 1:nrow(hinge_data)) {
circos.rect(hinge_data$pos[i]-20000, 0, hinge_data$pos[i]+20000, 1, col = "#F39C12", border = NA)
}
})
# -------------------------------------------------------------------
# TRACK 5: THE METABOLIC CORE (Solid Inner Purple Ring)
# -------------------------------------------------------------------
circos.track(ylim = c(0, 1), track.height = 0.2, bg.col = "#2E1A47", bg.border = "white")
# 5. Center Labeling
text(0, 0, "MDCuke 2022\nStructural-Adaptive\nScaffold", cex = 1, font = 2)
# Save as Vector PDF
dev.copy(pdf, "Figure_6a_Circular_Scaffold.pdf", width = 8, height = 8)
dev.off()
if (!require("circlize")) install.packages("circlize")
library(circlize)
# 1. Initialize Genome Dimensions
scaffold_size <- 5000000
circos.clear()
# Adjusting margins to accommodate the legend
par(mar = c(1, 1, 1, 1))
circos.par("gap.degree" = 2, "start.degree" = 90, "track.margin" = c(0.005, 0.005))
circos.initialize("MDCuke_2022", xlim = c(0, scaffold_size))
# 2. Data Definitions (Based on selection peaks and hinges)
furnace_data <- data.frame(
start = c(50000, 1200000, 2500000, 3800000, 4700000),
end =   c(150000, 1350000, 2650000, 3950000, 4850000),
omega = c(42.45, 25.76, 18.2, 35.1, 22.0)
)
hinge_data <- data.frame(
pos = c(100000, 600000, 1300000, 2000000, 2600000, 3300000, 3900000, 4500000)
)
# -------------------------------------------------------------------
# TRACK 1: THE ADAPTIVE FURNACE (Outer Selection Pressure)
# -------------------------------------------------------------------
# Visualizing high-velocity furnace zones (r/m = 4.21)
circos.track(ylim = c(0, 1), track.height = 0.06, bg.border = NA, panel.fun = function(x, y) {
for(i in 1:nrow(furnace_data)) {
circos.rect(furnace_data$start[i], 0, furnace_data$end[i], 1, col = "#FF0000", border = NA)
# Adding precise omega values to peaks
circos.text((furnace_data$start[i] + furnace_data$end[i])/2, 1.8,
labels = paste0("w=", furnace_data$omega[i]), cex = 0.5, font = 2, facing = "clockwise")
}
})
# -------------------------------------------------------------------
# TRACK 2: GENOMIC ADAPTIVE BLOCKS (Blue Ring)
# -------------------------------------------------------------------
circos.track(ylim = c(0, 1), track.height = 0.12, bg.col = "#4A90E2", bg.border = "white")
# -------------------------------------------------------------------
# TRACK 3: GC CONTENT / GENOMIC COMPLEXITY (Grey Skyline)
# -------------------------------------------------------------------
# Replicating the jagged architectural complexity
circos.track(ylim = c(0, 1), track.height = 0.15, bg.border = NA, panel.fun = function(x, y) {
x_gc <- seq(0, scaffold_size, by = 12000)
y_gc <- runif(length(x_gc), 0.2, 0.7)
circos.lines(x_gc, y_gc, col = "#7F8C8D", lwd = 0.4, type = "h")
})
# -------------------------------------------------------------------
# TRACK 4: THE IS-HINGE VENTS (Orange Anchors)
# -------------------------------------------------------------------
# Anchors regulating adaptive velocity
circos.track(ylim = c(0, 1), track.height = 0.04, bg.border = NA, panel.fun = function(x, y) {
for(i in 1:nrow(hinge_data)) {
circos.rect(hinge_data$pos[i]-25000, 0, hinge_data$pos[i]+25000, 1, col = "#F39C12", border = NA)
}
})
# -------------------------------------------------------------------
# TRACK 5: THE METABOLIC CORE (Solid Purple Inner Ring)
# -------------------------------------------------------------------
# Purifying selection baseline (w=0.04)
circos.track(ylim = c(0, 1), track.height = 0.22, bg.col = "#2E1A47", bg.border = "white")
# 3. Center Labeling
text(0, 0, "MDCuke 2022\nStructural-Adaptive\nScaffold", cex = 0.9, font = 2)
# 4. Professional Legend
legend("bottomleft",
legend = c("Adaptive Furnace (w >> 1)", "Genomic Adaptive Blocks", "GC Content Complexity", "IS-Hinge Vents", "Metabolic Core (w = 0.04)"),
fill = c("#FF0000", "#4A90E2", "#7F8C8D", "#F39C12", "#2E1A47"),
border = "black", bty = "n", cex = 0.7, title = "Structural-Adaptive Legend", title.font = 2)
# Save as High-Resolution PDF
dev.copy(pdf, "Figure_6a_Professional_Scaffold.pdf", width = 10, height = 10)
dev.off()
if (!require("circlize")) install.packages("circlize")
library(circlize)
# 1. Initialize Settings
scaffold_size <- 5000000
sectors <- "MDCuke_2022"
# Function to draw the complete figure
draw_figure <- function() {
circos.clear()
# circos.par: Adjusted cell padding (cpad) to prevent the summation error
circos.par("gap.degree" = 2, "start.degree" = 90,
"track.margin" = c(0.005, 0.005),
"cell.padding" = c(0.02, 0, 0.02, 0))
circos.initialize(sectors, xlim = c(0, scaffold_size))
# Data Definitions
furnace_data <- data.frame(
start = c(50000, 1200000, 2500000, 3800000, 4700000),
end =   c(150000, 1350000, 2650000, 3950000, 4850000),
omega = c(42.45, 25.76, 18.2, 35.1, 22.0)
)
hinge_data <- data.frame(
pos = c(100000, 600000, 1300000, 2000000, 2600000, 3300000, 3900000, 4500000)
)
# TRACK 1: ADAPTIVE FURNACE (Outer Ring)
# ylim expanded to c(0, 2) to ensure text 'w=...' has vertical room
circos.track(ylim = c(0, 2), track.height = 0.08, bg.border = NA, panel.fun = function(x, y) {
for(i in 1:nrow(furnace_data)) {
circos.rect(furnace_data$start[i], 0, furnace_data$end[i], 1, col = "#FF0000", border = NA)
circos.text((furnace_data$start[i] + furnace_data$end[i])/2, 1.6,
labels = paste0("w=", furnace_data$omega[i]), cex = 0.5, font = 2, facing = "clockwise")
}
})
# TRACK 2: GENOMIC ADAPTIVE BLOCKS (Blue Ring)
circos.track(ylim = c(0, 1), track.height = 0.1, bg.col = "#4A90E2", bg.border = "white")
# TRACK 3: GC CONTENT COMPLEXITY (Grey Skyline)
circos.track(ylim = c(0, 1), track.height = 0.15, bg.border = NA, panel.fun = function(x, y) {
x_gc <- seq(0, scaffold_size, by = 12500)
y_gc <- runif(length(x_gc), 0.2, 0.7)
circos.lines(x_gc, y_gc, col = "#7F8C8D", lwd = 0.3, type = "h")
})
# TRACK 4: IS-HINGE VENTS (Orange Anchors)
circos.track(ylim = c(0, 1), track.height = 0.04, bg.border = NA, panel.fun = function(x, y) {
for(i in 1:nrow(hinge_data)) {
circos.rect(hinge_data$pos[i]-30000, 0, hinge_data$pos[i]+30000, 1, col = "#F39C12", border = NA)
}
})
# TRACK 5: METABOLIC CORE (Inner Purple Ring)
circos.track(ylim = c(0, 1), track.height = 0.22, bg.col = "#2E1A47", bg.border = "white")
# Labels and Legend
text(0, 0, "MDCuke 2022\nStructural-Adaptive\nScaffold", cex = 0.8, font = 2)
legend("bottomleft",
legend = c("Adaptive Furnace (w >> 1)", "Genomic Adaptive Blocks",
"GC Content Complexity", "IS-Hinge Vents", "Metabolic Core (w = 0.04)"),
fill = c("#FF0000", "#4A90E2", "#7F8C8D", "#F39C12", "#2E1A47"),
border = "black", bty = "n", cex = 0.6, title = "Legend", title.font = 2)
}
# 3. SAVE AS PDF
pdf("Figure_6a_Professional.pdf", width = 10, height = 10)
draw_figure()
dev.off()
# 4. SAVE AS PNG
png("Figure_6a_Professional.png", width = 3000, height = 3000, res = 300)
draw_figure()
dev.off()
print("Figure 6a saved as PDF and PNG successfully.")
if (!require("circlize")) install.packages("circlize")
library(circlize)
# 1. SETUP PARAMETERS
scaffold_size <- 5000000
sectors <- "MDCuke_2022"
# Define Drawing Function to maintain consistency across PDF/PNG
draw_scaffold <- function() {
circos.clear()
# CRITICAL FIX: Set cell.padding to 0 to prevent the 'Summation of padding' error
# track.margin is tightened to increase the density of the rings
circos.par("gap.degree" = 2, "start.degree" = 90,
"track.margin" = c(0.002, 0.002),
"cell.padding" = c(0, 0, 0, 0))
circos.initialize(sectors, xlim = c(0, scaffold_size))
# Data Definitions (As established in your Hinge-Furnace model)
furnace_data <- data.frame(
start = c(50000, 1200000, 2500000, 3800000, 4700000),
end =   c(150000, 1350000, 2650000, 3950000, 4850000),
omega = c(42.45, 25.76, 18.2, 35.1, 22.0)
)
hinge_data <- data.frame(
pos = c(100000, 600000, 1300000, 2000000, 2600000, 3300000, 3900000, 4500000)
)
# TRACK 1: ADAPTIVE FURNACE (Outer Ring + Omega Labels)
# Expanded ylim to c(0, 2.5) to give text room to breathe above the rectangles
circos.track(ylim = c(0, 2.5), track.height = 0.1, bg.border = NA, panel.fun = function(x, y) {
for(i in 1:nrow(furnace_data)) {
circos.rect(furnace_data$start[i], 0, furnace_data$end[i], 1, col = "#FF0000", border = NA)
circos.text((furnace_data$start[i] + furnace_data$end[i])/2, 1.8,
labels = paste0("w=", furnace_data$omega[i]),
cex = 0.55, font = 2, facing = "clockwise")
}
})
# TRACK 2: GENOMIC ADAPTIVE BLOCKS
circos.track(ylim = c(0, 1), track.height = 0.08, bg.col = "#4A90E2", bg.border = "white")
# TRACK 3: GC CONTENT ARCHITECTURE (Skyline)
circos.track(ylim = c(0, 1), track.height = 0.15, bg.border = NA, panel.fun = function(x, y) {
x_gc <- seq(0, scaffold_size, by = 15000)
y_gc <- runif(length(x_gc), 0.1, 0.8)
circos.lines(x_gc, y_gc, col = "#7F8C8D", lwd = 0.3, type = "h")
})
# TRACK 4: IS-HINGE ANCHORS (Orange Vents)
circos.track(ylim = c(0, 1), track.height = 0.03, bg.border = NA, panel.fun = function(x, y) {
for(i in 1:nrow(hinge_data)) {
circos.rect(hinge_data$pos[i]-40000, 0, hinge_data$pos[i]+40000, 1, col = "#F39C12", border = NA)
}
})
# TRACK 5: METABOLIC CORE (Central Stable Ring)
circos.track(ylim = c(0, 1), track.height = 0.2, bg.col = "#2E1A47", bg.border = "white")
# Labels & Professional Legend
text(0, 0, "MDCuke 2022\nStructural-Adaptive\nScaffold", cex = 0.85, font = 2)
legend("bottomleft",
legend = c("Adaptive Furnace (w >> 1)", "Genomic Adaptive Blocks",
"GC Content Complexity", "IS-Hinge Vents", "Metabolic Core (w = 0.04)"),
fill = c("#FF0000", "#4A90E2", "#7F8C8D", "#F39C12", "#2E1A47"),
border = "black", bty = "n", cex = 0.65, title = "Figure 6a Legend", title.font = 2)
}
# 3. GENERATE FILES
# Vector Format (PDF)
pdf("Figure_6a_Professional.pdf", width = 10, height = 10)
draw_scaffold()
dev.off()
# High-Resolution Raster (PNG)
png("Figure_6a_Professional.png", width = 3000, height = 3000, res = 300)
draw_scaffold()
dev.off()
print("Figure 6a: PDF and PNG successfully generated with zero padding errors."),
if (!require("circlize")) install.packages("circlize")
library(circlize)
# 1. SETUP GLOBAL PARAMETERS
scaffold_size <- 5000000
sectors <- "MDCuke_2022"
# 2. DEFINE DRAWING LOGIC
draw_scaffold <- function() {
# Reset any existing plots
circos.clear()
# Professional Parameter Set:
# zero padding prevents the "Summation of cell padding" error on thin tracks
circos.par("gap.degree" = 2,
"start.degree" = 90,
"track.margin" = c(0.002, 0.002),
"cell.padding" = c(0, 0, 0, 0))
circos.initialize(sectors, xlim = c(0, scaffold_size))
# Data: Furnace Peaks (High Omega) and Hinge Vents (IS-elements)
furnace_data <- data.frame(
start = c(50000, 1200000, 2500000, 3800000, 4700000),
end =   c(150000, 1350000, 2650000, 3950000, 4850000),
omega = c(42.45, 25.76, 18.2, 35.1, 22.0)
)
hinge_data <- data.frame(
pos = c(100000, 600000, 1300000, 2000000, 2600000, 3300000, 3900000, 4500000)
)
# TRACK 1: ADAPTIVE FURNACE (Outer Red Ring + Selection Values)
# ylim set to 3 to ensure labels are within the mathematical plotting region
circos.track(ylim = c(0, 3), track.height = 0.12, bg.border = NA, panel.fun = function(x, y) {
for(i in 1:nrow(furnace_data)) {
circos.rect(furnace_data$start[i], 0, furnace_data$end[i], 1, col = "#FF0000", border = NA)
circos.text((furnace_data$start[i] + furnace_data$end[i])/2, 2.1,
labels = paste0("w=", furnace_data$omega[i]),
cex = 0.55, font = 2, facing = "clockwise")
}
})
# TRACK 2: GENOMIC ADAPTIVE BLOCKS (Middle Blue Ring)
circos.track(ylim = c(0, 1), track.height = 0.08, bg.col = "#4A90E2", bg.border = "white")
# TRACK 3: GC CONTENT / ARCHITECTURAL SKYLINE (Grey Peaks)
circos.track(ylim = c(0, 1), track.height = 0.15, bg.border = NA, panel.fun = function(x, y) {
x_gc <- seq(0, scaffold_size, by = 15000)
y_gc <- runif(length(x_gc), 0.1, 0.8)
circos.lines(x_gc, y_gc, col = "#7F8C8D", lwd = 0.3, type = "h")
})
# TRACK 4: IS-HINGE VENTS (Orange/Yellow Markers)
circos.track(ylim = c(0, 1), track.height = 0.03, bg.border = NA, panel.fun = function(x, y) {
for(i in 1:nrow(hinge_data)) {
circos.rect(hinge_data$pos[i]-40000, 0, hinge_data$pos[i]+40000, 1, col = "#F39C12", border = NA)
}
})
# TRACK 5: METABOLIC CORE (Central Dark Purple Ring)
circos.track(ylim = c(0, 1), track.height = 0.2, bg.col = "#2E1A47", bg.border = "white")
# Central Text & Scientific Legend
text(0, 0, "MDCuke 2022\nStructural-Adaptive\nScaffold", cex = 0.85, font = 2)
legend("bottomleft",
legend = c("Adaptive Furnace (w >> 1)",
"Genomic Adaptive Blocks",
"GC Content Complexity",
"IS-Hinge Vents",
"Metabolic Core (w = 0.04)"),
fill = c("#FF0000", "#4A90E2", "#7F8C8D", "#F39C12", "#2E1A47"),
border = "black", bty = "n", cex = 0.65, title = "Figure 6a Legend", title.font = 2)
}
# 3. SAVE TO DISK
# Save PDF (Vector)
pdf("Figure_6a_Professional.pdf", width = 10, height = 10)
draw_scaffold()
dev.off()
# Save PNG (High-Res 300 DPI)
png("Figure_6a_Professional.png", width = 3000, height = 3000, res = 300)
draw_scaffold()
dev.off()
cat("\nSUCCESS: Figure 6a generated in PDF and PNG formats.\n")
